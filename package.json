    "dotenv": "^17.4.2",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "pmtiles": "^4.4.1",
    "prisma": "^7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
