{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "echo importer-install-only",
    "watchPatterns": [
      "package.json",
      "package-lock.json",
      "prisma/**",
      "scripts/import-amenities.ts",
      "scripts/amenities/**",
      "src/features/amenities/**",
      "src/lib/**",
      "railway.importer.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run amenities:refresh",
    "cronSchedule": "0 3 * * 0",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 2
  }
}
