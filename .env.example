# ── Required ────────────────────────────────────────────────────────────────
# PostgreSQL/PostGIS connection. Local dev: docker compose up -d db (port 5433).
# Railway: use the private-network URL from the PostGIS service.
DATABASE_URL="postgresql://howfar:howfar@localhost:5433/howfar"

# Optional outside local Docker: Prisma migrate dev's dedicated shadow DB.
# Production `prisma migrate deploy` does not read it.
SHADOW_DATABASE_URL="postgresql://howfar:howfar@localhost:5433/howfar_shadow"

# Auth.js session/JWT secret — ALWAYS required at runtime, even before OAuth
# providers are configured. Generate: npx auth secret  (or openssl rand -base64 32)
AUTH_SECRET=""

# ── Optional: social login (sign-in UI stays hidden while unset) ────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── Optional: providers (server-side only — never expose under NEXT_PUBLIC_) ─
# OpenRouteService key for walking isochrones (free account: openrouteservice.org)
ORS_API_KEY=""

# Optional importer failure webhook (Railway/Slack-compatible JSON receiver).
# The weekly job also exits non-zero and /api/catalogue-status returns 503 when stale.
AMENITY_IMPORT_ALERT_WEBHOOK_URL=""
